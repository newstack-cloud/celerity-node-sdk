{
  "name": "@celerity-sdk/topic",
  "version": "0.8.0",
  "description": "Pub/Sub topic abstraction for the Celerity Node SDK (SNS / Pub/Sub / Service Bus Topics)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/newstack-cloud/celerity-node-sdk.git",
    "directory": "packages/topic"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@celerity-sdk/types": "workspace:^",
    "@celerity-sdk/common": "workspace:^",
    "@celerity-sdk/config": "workspace:^",
    "debug": "^4.4.0"
  },
  "devDependencies": {
    "@aws-sdk/client-sns": "^3.1022.0",
    "@aws-sdk/client-sqs": "^3.1022.0",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-sns": "^3.0.0",
    "@google-cloud/pubsub": "^4.0.0",
    "@azure/service-bus": "^7.0.0",
    "ioredis": "^5.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-sns": {
      "optional": true
    },
    "@google-cloud/pubsub": {
      "optional": true
    },
    "@azure/service-bus": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
