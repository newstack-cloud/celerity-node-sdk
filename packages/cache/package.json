{
  "name": "@celerity-sdk/cache",
  "version": "0.8.1",
  "description": "Cache abstraction for the Celerity Node SDK (ElastiCache / Memorystore / Azure Cache for Redis)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/newstack-cloud/celerity-node-sdk.git",
    "directory": "packages/cache"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@celerity-sdk/types": "workspace:^",
    "@celerity-sdk/common": "workspace:^",
    "@celerity-sdk/config": "workspace:^",
    "debug": "^4.4.0"
  },
  "devDependencies": {
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.2.0",
    "@smithy/signature-v4": "^5.3.13",
    "@smithy/protocol-http": "^4.0.0",
    "@aws-crypto/sha256-js": "^5.0.0",
    "@aws-sdk/credential-provider-node": "^3.750.0"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "@smithy/signature-v4": "^5.3.13",
    "@smithy/protocol-http": "^4.0.0",
    "@aws-crypto/sha256-js": "^5.0.0",
    "@aws-sdk/credential-provider-node": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    },
    "@smithy/signature-v4": {
      "optional": true
    },
    "@smithy/protocol-http": {
      "optional": true
    },
    "@aws-crypto/sha256-js": {
      "optional": true
    },
    "@aws-sdk/credential-provider-node": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
