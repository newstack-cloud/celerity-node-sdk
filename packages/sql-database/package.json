{
  "name": "@celerity-sdk/sql-database",
  "version": "0.3.1",
  "description": "SQL database credentials provider and Knex.js connection factory for the Celerity Node SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/newstack-cloud/celerity-node-sdk.git",
    "directory": "packages/sql-database"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@celerity-sdk/types": "workspace:^",
    "@celerity-sdk/common": "workspace:^",
    "@celerity-sdk/config": "workspace:^",
    "debug": "^4.4.0"
  },
  "devDependencies": {
    "@aws-sdk/rds-signer": "^3.750.0",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependencies": {
    "@aws-sdk/rds-signer": "^3.0.0",
    "knex": "^3.0.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/rds-signer": {
      "optional": true
    },
    "knex": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
